# Compliance Checker — lokális dev környezeti változók
# Másold át `.env`-re és töltsd ki a saját értékeiddel.
#
# A .env fájl a .gitignore-ban van, NEM kerül commitba.

# ─── KÖTELEZŐ ─────────────────────────────────────────────────────────────────

# MySQL/TiDB connection string. Docker-compose-zal:
DATABASE_URL=mysql://compliance:compliance_dev_pw@127.0.0.1:3306/compliance_checker

# Session-cookie aláírási kulcs (egy random hosszú string is jó dev-re).
# Ez lesz az AES-256-CBC platform-credential titkosítás kulcsának forrása is.
JWT_SECRET=local-dev-jwt-secret-please-change-me-32-chars-or-more

# ─── DEV-MÓDÚ AUTH BYPASS ─────────────────────────────────────────────────────
# Manus OAuth lokálisan nem érhető el, ezért a context.ts-ben van egy env-gated
# bypass. Ha be van állítva, minden request a `seed-dev-user.mjs`-szel létrehozott
# usernek látszik. Production-ben SOSE állítsd be ezt a változót.
#
# Tipikus folyamat:
#   1. docker compose up -d
#   2. pnpm install
#   3. pnpm db:push           # séma migráció
#   4. node seed-dev-user.mjs # user létrehozása ID=1 admin szerepkörrel
#   5. LOCAL_DEV_USER_ID=1    # ide írd
#   6. pnpm dev
LOCAL_DEV_USER_ID=

# ─── OPCIONÁLIS — LLM / EMBEDDINGS ────────────────────────────────────────────
# V11.13 Manus-leválasztás után az új primary path az OpenAI direkt API.
# Ha az OPENAI_API_KEY be van állítva, a kód OpenAI-t használ. Ha üres és a
# legacy BUILT_IN_FORGE_* be van állítva, a Manus forge-ot. Ha egyik sem,
# az LLM-igénylő flow-k (Szabványkereső, compliance-elemzés, embeddings)
# graceful módon hibára esnek vagy keyword-only-ra fallback-elnek.

# OpenAI direct (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
# Default chat-completion modell. Olcsóbb: gpt-4o-mini. Erősebb: gpt-4o, gpt-4.1.
LLM_MODEL=gpt-4o-mini
# Default embedding modell. Olcsó és jó: text-embedding-3-small (1536 dim).
EMBEDDING_MODEL=text-embedding-3-small
# OpenRouter / Azure OpenAI esetén override: pl. https://openrouter.ai vagy https://YOUR.openai.azure.com
OPENAI_BASE_URL=https://api.openai.com

# Legacy — Manus forge fallback (csak Manus-deploy-on releváns)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── OPCIONÁLIS — MANUS OAUTH ─────────────────────────────────────────────────
# Csak prod-on releváns. Lokálisan a LOCAL_DEV_USER_ID bypass-szal dolgozunk.
VITE_APP_ID=
OAUTH_SERVER_URL=

# ─── OPCIONÁLIS FEATURE-FLAGS ─────────────────────────────────────────────────

# Élő MSZT-keresés (V11.0+ kísérleti). Csak mszt-credential beállítása után aktív.
# ENABLE_LIVE_MSZT_SEARCH=true

# Email-küldés (V11.11). Üres = csak in-app notification, nincs SMTP.
# SMTP_HOST=
